# ─────────────────────────────────────────────
# mosafer-spine.de — Apache Konfiguration
# Kanonische Domain: https://www.mosafer-spine.de
# ─────────────────────────────────────────────

AddDefaultCharset UTF-8

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

RewriteEngine On

# Alle Varianten auf https://www. weiterleiten (301 permanent)
# Betrifft: http://, https://, non-www, www ohne HTTPS
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\.mosafer-spine\.de$ [NC]
RewriteRule ^ https://www.mosafer-spine.de%{REQUEST_URI} [R=301,L]
